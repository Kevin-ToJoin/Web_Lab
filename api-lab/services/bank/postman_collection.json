{
  "info": {
    "name": "TestLab 101 — Vault Online (Bank module)",
    "description": "A deliberately-buggy banking backend for QA practice. Each request targets one or more injected bugs. Reveal the tagged answers at GET /_lab/bugs?key=REVEAL.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [{ "key": "baseUrl", "value": "http://localhost:4001" }],
  "item": [
    { "name": "Lab — requirements", "request": { "method": "GET", "url": "{{baseUrl}}/_lab/requirements" } },
    { "name": "Lab — reveal tagged bugs", "request": { "method": "GET", "url": "{{baseUrl}}/_lab/bugs?key=REVEAL" } },
    { "name": "Health (correct here — compare vs ecommerce)", "request": { "method": "GET", "url": "{{baseUrl}}/health" } },
    {
      "name": "Account — IDOR: read another user's account (BANK-06)",
      "request": { "method": "GET", "header": [{ "key": "X-User-Id", "value": "2" }], "url": "{{baseUrl}}/accounts/1" }
    },
    { "name": "Account — missing id returns 200 null (BANK-10)", "request": { "method": "GET", "url": "{{baseUrl}}/accounts/9999" } },
    { "name": "Statement — doesn't reconcile (BANK-09)", "request": { "method": "GET", "url": "{{baseUrl}}/accounts/1/statement" } },
    {
      "name": "Transfer — overdraft, goes negative (BANK-02)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-User-Id", "value": "1" }],
        "body": { "mode": "raw", "raw": "{\n  \"fromId\": 4,\n  \"toId\": 1,\n  \"amount\": 999999\n}" },
        "url": "{{baseUrl}}/transfers"
      }
    },
    {
      "name": "Transfer — negative amount accepted (BANK-07)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-User-Id", "value": "1" }],
        "body": { "mode": "raw", "raw": "{\n  \"fromId\": 1,\n  \"toId\": 3,\n  \"amount\": -100\n}" },
        "url": "{{baseUrl}}/transfers"
      }
    },
    {
      "name": "Transfer — to nonexistent account destroys funds (BANK-08)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-User-Id", "value": "1" }],
        "body": { "mode": "raw", "raw": "{\n  \"fromId\": 1,\n  \"toId\": 9999,\n  \"amount\": 50\n}" },
        "url": "{{baseUrl}}/transfers"
      }
    },
    {
      "name": "Transfer — crash after debit, not atomic (BANK-01)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-User-Id", "value": "1" }],
        "body": { "mode": "raw", "raw": "{\n  \"fromId\": 1,\n  \"toId\": 3,\n  \"amount\": 25,\n  \"simulateCrash\": true\n}" },
        "url": "{{baseUrl}}/transfers"
      }
    },
    {
      "name": "Transfer — repeat Idempotency-Key posts twice (BANK-05)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Id", "value": "1" },
          { "key": "Idempotency-Key", "value": "bank-demo-1" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"fromId\": 1,\n  \"toId\": 3,\n  \"amount\": 10\n}" },
        "url": "{{baseUrl}}/transfers"
      }
    },
    {
      "name": "Transfer — malformed payload returns 500 (BANK-11)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"amount\": \"lots\"\n}" },
        "url": "{{baseUrl}}/transfers"
      }
    },
    { "name": "Admin — accounts leak, no authz (BANK-12)", "request": { "method": "GET", "url": "{{baseUrl}}/admin/accounts" } }
  ]
}
